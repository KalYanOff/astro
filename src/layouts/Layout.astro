---
import {
  SITE_AVAILABLE_LANGUAGE_CODES,
  SITE_CHECKIN_TIME,
  SITE_CHECKOUT_TIME,
  SITE_CLASSIFICATION_REGISTRY_ID,
  SITE_COORDS,
  SITE_CURRENCIES_ACCEPTED,
  SITE_EMAIL,
  SITE_INN,
  SITE_LEGAL_NAME,
  SITE_MAP_URL,
  SITE_NUMBER_OF_ROOMS,
  SITE_OBJECT_STATUS,
  SITE_OGRNIP,
  SITE_PAYMENT_ACCEPTED,
  SITE_PETS_ALLOWED,
  SITE_PHONE_DISPLAY,
  SITE_REFERENCE_LINKS,
} from '../config/site.js';
import { TL_CONTEXT, TL_LANG } from '../config/travelline.js';
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_OG_IMAGE,
  DEFAULT_TITLE,
  type BreadcrumbItem,
  getSeoProfile,
  ORG_NAME,
  type SeoProfileId,
  SITE_URL,
  toCanonical,
} from '../config/seo';

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
  breadcrumbs?: BreadcrumbItem[];
  ogImage?: string;
  schemaPageName?: string;
  seoProfileId?: SeoProfileId;
  extraJsonLd?: Record<string, unknown>[];
}

const {
  title = DEFAULT_TITLE,
  description = DEFAULT_DESCRIPTION,
  canonicalPath = '/',
  noindex = false,
  breadcrumbs = [],
  ogImage = DEFAULT_OG_IMAGE,
  schemaPageName,
  seoProfileId,
  extraJsonLd = [],
} = Astro.props;

const seoProfile = getSeoProfile(seoProfileId);

const resolvedTitle = seoProfile?.title ?? title;
const resolvedDescription = seoProfile?.description ?? description;
const resolvedCanonicalPath = seoProfile?.canonicalPath ?? canonicalPath;
const resolvedOgTitle = seoProfile?.ogTitle ?? resolvedTitle;
const resolvedOgDescription = seoProfile?.ogDescription ?? resolvedDescription;
const keywordsContent = seoProfile?.focusKeywords.join(', ');

const canonicalUrl = toCanonical(resolvedCanonicalPath);
const robotsContent = noindex ? 'noindex,follow' : 'index,follow';
const pageName = schemaPageName || resolvedTitle;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : toCanonical(ogImage);

const [latitude, longitude] = SITE_COORDS.split(',').map((value) => Number(value.trim()));
const isIndexedSeoPage = Boolean(seoProfile && !noindex);
const includeHotelSchema = Boolean(isIndexedSeoPage && seoProfile?.includeHotelSchema);

const postalAddress = {
  '@type': 'PostalAddress',
  streetAddress: 'Набережная 7',
  addressLocality: 'Джубга',
  addressRegion: 'Краснодарский край',
  postalCode: '352844',
  addressCountry: 'RU',
};

const geoCoordinates = {
  '@type': 'GeoCoordinates',
  latitude,
  longitude,
};

const businessIdentifiers = [
  {
    '@type': 'PropertyValue',
    name: 'Номер в реестре классифицированных средств размещения',
    value: SITE_CLASSIFICATION_REGISTRY_ID,
  },
  {
    '@type': 'PropertyValue',
    name: 'ИНН',
    value: SITE_INN,
  },
  {
    '@type': 'PropertyValue',
    name: 'ОГРНИП',
    value: SITE_OGRNIP,
  },
];

const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: ORG_NAME,
  legalName: SITE_LEGAL_NAME,
  url: SITE_URL,
  logo: toCanonical('/img/logo.webp'),
  email: SITE_EMAIL,
  telephone: SITE_PHONE_DISPLAY,
  sameAs: SITE_REFERENCE_LINKS,
  identifier: businessIdentifiers,
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: ORG_NAME,
  url: SITE_URL,
  inLanguage: 'ru-RU',
};

const webpageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: pageName,
  url: canonicalUrl,
  description: resolvedDescription,
  inLanguage: 'ru-RU',
  isPartOf: {
    '@type': 'WebSite',
    name: ORG_NAME,
    url: SITE_URL,
  },
  mainEntity: isIndexedSeoPage
    ? {
        '@type': 'LodgingBusiness',
        name: ORG_NAME,
        url: SITE_URL,
      }
    : undefined,
};

const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: ORG_NAME,
  url: SITE_URL,
  image: ogImageUrl,
  telephone: SITE_PHONE_DISPLAY,
  email: SITE_EMAIL,
  address: postalAddress,
  geo: geoCoordinates,
  areaServed: 'RU',
  description: resolvedDescription,
  priceRange: '₽₽',
  openingHours: 'Mo-Su 00:00-23:59',
  hasMap: SITE_MAP_URL,
  sameAs: SITE_REFERENCE_LINKS,
  identifier: businessIdentifiers,
};

const hotelAmenityFeatures = [
  {
    '@type': 'LocationFeatureSpecification',
    name: 'Wi-Fi',
    value: true,
  },
  {
    '@type': 'LocationFeatureSpecification',
    name: 'Парковка',
    value: true,
  },
  {
    '@type': 'LocationFeatureSpecification',
    name: 'Близость к пляжу',
    value: true,
  },
  {
    '@type': 'LocationFeatureSpecification',
    name: 'Семейный отдых',
    value: true,
  },
  {
    '@type': 'LocationFeatureSpecification',
    name: 'Кухня для гостей',
    value: true,
  },
  {
    '@type': 'LocationFeatureSpecification',
    name: 'Зона барбекю',
    value: true,
  },
  {
    '@type': 'LocationFeatureSpecification',
    name: 'Детская площадка',
    value: true,
  },
];

const lodgingBusinessSchema =
  isIndexedSeoPage
    ? {
        '@context': 'https://schema.org',
        '@type': 'LodgingBusiness',
        name: ORG_NAME,
        url: canonicalUrl,
        description: resolvedDescription,
        image: ogImageUrl,
        telephone: SITE_PHONE_DISPLAY,
        email: SITE_EMAIL,
        priceRange: '₽₽',
        checkinTime: SITE_CHECKIN_TIME,
        checkoutTime: SITE_CHECKOUT_TIME,
        address: postalAddress,
        geo: geoCoordinates,
        amenityFeature: hotelAmenityFeatures,
        availableLanguage: SITE_AVAILABLE_LANGUAGE_CODES,
        paymentAccepted: SITE_PAYMENT_ACCEPTED,
        currenciesAccepted: SITE_CURRENCIES_ACCEPTED,
        petsAllowed: SITE_PETS_ALLOWED,
        numberOfRooms: SITE_NUMBER_OF_ROOMS,
        keywords: seoProfile.focusKeywords.join(', '),
        hasMap: SITE_MAP_URL,
        sameAs: SITE_REFERENCE_LINKS,
        identifier: businessIdentifiers,
        slogan: SITE_OBJECT_STATUS,
      }
    : null;

const hotelSchema =
  includeHotelSchema
    ? {
        '@context': 'https://schema.org',
        '@type': 'Hotel',
        name: ORG_NAME,
        url: canonicalUrl,
        description: resolvedDescription,
        image: ogImageUrl,
        telephone: SITE_PHONE_DISPLAY,
        email: SITE_EMAIL,
        priceRange: '₽₽',
        checkinTime: SITE_CHECKIN_TIME,
        checkoutTime: SITE_CHECKOUT_TIME,
        address: postalAddress,
        geo: geoCoordinates,
        amenityFeature: hotelAmenityFeatures,
        availableLanguage: SITE_AVAILABLE_LANGUAGE_CODES,
        paymentAccepted: SITE_PAYMENT_ACCEPTED,
        currenciesAccepted: SITE_CURRENCIES_ACCEPTED,
        petsAllowed: SITE_PETS_ALLOWED,
        numberOfRooms: SITE_NUMBER_OF_ROOMS,
        keywords: seoProfile.focusKeywords.join(', '),
        hasMap: SITE_MAP_URL,
        sameAs: SITE_REFERENCE_LINKS,
        identifier: businessIdentifiers,
      }
    : null;

const breadcrumbSchema = breadcrumbs.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: toCanonical(item.path),
      })),
    }
  : null;

const jsonLdSchemas = [
  organizationSchema,
  websiteSchema,
  webpageSchema,
  localBusinessSchema,
  ...(hotelSchema ? [hotelSchema] : []),
  ...(lodgingBusinessSchema ? [lodgingBusinessSchema] : []),
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...extraJsonLd,
];

const travelLineHeadScript = `
  (function(w) {
    var q = [
      ["setContext", "${TL_CONTEXT}", "${TL_LANG}"],
      ["embed", "search-form", { container: "tl-search-form" }]
    ];
    var h = ["ru-ibe.tlintegration.ru", "ibe.tlintegration.ru", "ibe.tlintegration.com"];
    var t = w.travelline = (w.travelline || {}),
      ti = t.integration = (t.integration || {});
    ti.__cq = ti.__cq ? ti.__cq.concat(q) : q;
    if (!ti.__loader) {
      ti.__loader = true;
      var d = w.document, c = d.getElementsByTagName("head")[0] || d.getElementsByTagName("body")[0];
      function e(s, f) { return function() { w.TL || (c.removeChild(s), f()) } }
      (function l(h) {
        if (0 === h.length) return;
        var s = d.createElement("script");
        s.type = "text/javascript";
        s.async = true;
        s.src = "https://" + h[0] + "/integration/loader.js";
        s.onerror = s.onload = e(s, function() { l(h.slice(1, h.length)) });
        c.appendChild(s);
      })(h);
    }
  })(window);
`;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    {keywordsContent && <meta name="keywords" content={keywordsContent} />}
    <meta name="robots" content={robotsContent} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={resolvedOgTitle} />
    <meta property="og:description" content={resolvedOgDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={ORG_NAME} />
    <meta property="og:image" content={ogImageUrl} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedOgTitle} />
    <meta name="twitter:description" content={resolvedOgDescription} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="application-name" content={ORG_NAME} />
    <meta name="apple-mobile-web-app-title" content={ORG_NAME} />

    {jsonLdSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- start TL head script -->
    <script type="text/javascript" set:html={travelLineHeadScript} />
    <!-- end TL head script -->

    <!-- Yandex.Metrika counter -->
    <script type="text/javascript">
        (function(m,e,t,r,i,k,a){
            m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
            m[i].l=1*new Date();
            for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
            k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)
        })(window, document,'script','https://mc.yandex.ru/metrika/tag.js?id=101427691', 'ym');

        ym(101427691, 'init', {ssr:true, webvisor:true, clickmap:true, ecommerce:"dataLayer", referrer: document.referrer, url: location.href, accurateTrackBounce:true, trackLinks:true});
    </script>
    <noscript><div><img src="https://mc.yandex.ru/watch/101427691" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
    <!-- /Yandex.Metrika counter -->

  </head>
  <body>
    <a class="skip-link" href="#main-content">Перейти к содержанию</a>

    {breadcrumbs.length > 1 && (
      <nav class="breadcrumbs" aria-label="Хлебные крошки">
        <ol>
          {breadcrumbs.map((item, index) => (
            <li>
              {index < breadcrumbs.length - 1 ? (
                <a href={item.path}>{item.name}</a>
              ) : (
                <span aria-current="page">{item.name}</span>
              )}
            </li>
          ))}
        </ol>
      </nav>
    )}

    <slot />
  </body>
</html>

<style is:global>
  html,
  body {
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100%;
    font-family:
      -apple-system,
      BlinkMacSystemFont,
      'Segoe UI',
      'Helvetica Neue',
      sans-serif;
    scroll-behavior: smooth;
  }

  * {
    box-sizing: border-box;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  :focus-visible {
    outline: 3px solid #f59e0b;
    outline-offset: 2px;
  }

  .skip-link {
    position: absolute;
    left: 0.5rem;
    top: 0.5rem;
    z-index: 200;
    transform: translateY(-160%);
    background: #0f172a;
    color: #fff;
    padding: 0.65rem 0.85rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 600;
  }

  .skip-link:focus {
    transform: translateY(0);
  }

  .breadcrumbs {
    width: min(1100px, calc(100% - 2rem));
    margin: 1rem auto 0;
    color: #475569;
    font-size: 0.9rem;
  }

  .breadcrumbs ol {
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
  }

  .breadcrumbs li + li::before {
    content: '/';
    margin-right: 0.5rem;
    color: #94a3b8;
  }

  .breadcrumbs a {
    color: #2563eb;
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
    }
  }

  .yarl__portal {
    pointer-events: none;
  }

  .yarl__portal_open {
    pointer-events: auto;
  }
</style>
