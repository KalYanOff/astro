---
import { readFileSync } from 'node:fs';
import Layout from '../../layouts/Layout.astro';

const documentText = readFileSync(new URL('../../../src/legal/offer.txt', import.meta.url), 'utf8')
  .replace(/^\uFEFF/, '')
  .trim();
const documentTitle = documentText.split('\n').find((line) => line.trim())?.trim() ?? 'Правила предоставления услуг';

const pageTitle = 'Правила предоставления услуг | Гостевой дом «Дельфин», Джубга';
const pageDescription =
  'Правила предоставления услуг гостевого дома «Дельфин»: бронирование, заселение, проживание, порядок пользования номером и условия размещения гостей.';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/docs/offer"
  noindex={true}
  schemaPageName={documentTitle}
  breadcrumbs={[
    { name: 'Главная', path: '/' },
    { name: documentTitle, path: '/docs/offer' },
  ]}
>
  <main id="main-content">
    <div class="min-h-screen bg-slate-50 py-12">
      <div class="container mx-auto max-w-5xl px-4">
        <div class="rounded-lg bg-white p-8 shadow-lg md:p-12">
          <div class="mb-8">
            <a href="/" class="font-medium text-primary-600 hover:text-primary-700">← На главную</a>
          </div>

          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl">
            <div class="p-8 md:p-12">
              <pre class="whitespace-pre-wrap font-sans text-sm leading-relaxed text-slate-800 md:text-base">{documentText}</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
