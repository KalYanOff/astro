---
import { readFileSync } from 'node:fs';
import Layout from '../../layouts/Layout.astro';
import {
  SITE_ADDRESS,
  SITE_CLASSIFICATION_REGISTRY_ID,
  SITE_EMAIL,
  SITE_LEGAL_NAME,
  SITE_OBJECT_STATUS,
  SITE_PHONE_DISPLAY,
} from '../../config/site.js';

const documentTitle = 'Политика обработки персональных данных';
const documentDate = '26.03.2026';
const documentText = readFileSync(new URL('../../../src/legal/privacy.txt', import.meta.url), 'utf8')
  .replace(/^\uFEFF/, '')
  .trim();

const bodyStartIndex = documentText.indexOf('1. Общие положения');
const documentBody = bodyStartIndex >= 0 ? documentText.slice(bodyStartIndex).trim() : documentText;

const pageTitle = 'Политика обработки персональных данных | Гостевой дом «Дельфин», Джубга';
const pageDescription =
  'Политика обработки персональных данных гостевого дома «Дельфин»: порядок обработки ПДн, меры защиты, cookies, видеонаблюдение и порядок обращений.';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonicalPath="/docs/privacy"
  noindex={true}
  schemaPageName={documentTitle}
  breadcrumbs={[
    { name: 'Главная', path: '/' },
    { name: documentTitle, path: '/docs/privacy' },
  ]}
>
  <main id="main-content">
    <div class="min-h-screen bg-slate-50 py-12">
      <div class="container mx-auto max-w-5xl px-4">
        <div class="rounded-lg bg-white p-8 shadow-lg md:p-12">
          <div class="mb-8">
            <a href="/" class="font-medium text-primary-600 hover:text-primary-700">← На главную</a>
          </div>

          <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-2xl">
            <div class="bg-gradient-to-r from-blue-600 to-indigo-700 p-8 text-white md:p-12">
              <p class="mb-3 text-center text-sm font-semibold uppercase tracking-[0.25em] text-blue-100">
                Официальный документ гостевого дома
              </p>
              <h1 class="text-center text-3xl font-bold md:text-4xl">{documentTitle}</h1>
              <p class="mt-4 text-center text-blue-100/90">Редакция от: {documentDate}</p>
            </div>

            <div class="border-b border-slate-200 bg-slate-50/70 p-8 md:p-12">
              <div class="grid gap-3 text-sm text-slate-700 md:grid-cols-2">
                <p><span class="font-semibold text-slate-900">Оператор:</span> {SITE_LEGAL_NAME}</p>
                <p><span class="font-semibold text-slate-900">Статус объекта:</span> {SITE_OBJECT_STATUS}</p>
                <p><span class="font-semibold text-slate-900">e-mail:</span> <a href={`mailto:${SITE_EMAIL}`} class="text-blue-600 underline hover:text-blue-800">{SITE_EMAIL}</a></p>
                <p><span class="font-semibold text-slate-900">Телефон:</span> {SITE_PHONE_DISPLAY}</p>
                <p><span class="font-semibold text-slate-900">Адрес:</span> {SITE_ADDRESS}</p>
                <p><span class="font-semibold text-slate-900">Реестр классификации:</span> {SITE_CLASSIFICATION_REGISTRY_ID}</p>
              </div>
            </div>

            <div class="p-8 md:p-12">
              <pre class="whitespace-pre-wrap font-sans text-sm leading-relaxed text-slate-800 md:text-base">{documentBody}</pre>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>
