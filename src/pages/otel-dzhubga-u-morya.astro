---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  seoProfileId="otel_u_morya"
  canonicalPath="/otel-dzhubga-u-morya"
  schemaPageName="Отдых у моря в Джубге"
  breadcrumbs={[
    { name: 'Главная', path: '/' },
    { name: 'Отдых у моря в Джубге', path: '/otel-dzhubga-u-morya' },
  ]}
>
  <Header />
  <main id="main-content" class="bg-slate-50">
    <section class="pt-32 pb-12">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="bg-white rounded-3xl shadow-lg p-8 md:p-12">
          <h1 class="text-3xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
            Первая береговая линия и спокойный отдых в Джубге
          </h1>
          <p class="text-lg text-slate-700 leading-relaxed mb-4">
            До пляжа можно дойти за пару минут. Локация подходит для тех, кто ценит удобный доступ к морю,
            вечерним прогулкам и инфраструктуре курорта.
          </p>
          <p class="text-lg text-slate-700 leading-relaxed mb-8">
            Форматы размещения под разные сценарии поездки: короткие заезды, семейные каникулы и отдых в кругу друзей.
            Мы поддерживаем комфортный темп отдыха и быстро отвечаем на заявки.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/#booking-request"
              class="inline-flex items-center justify-center min-h-11 px-6 py-3 rounded-xl bg-accent-500 hover:bg-accent-600 text-white font-semibold transition-colors"
            >
              Оставить заявку
            </a>
            <a
              href="/#features"
              class="inline-flex items-center justify-center min-h-11 px-6 py-3 rounded-xl bg-primary-600 hover:bg-primary-700 text-white font-semibold transition-colors"
            >
              Изучить преимущества
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
