---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import TravelLineSearch from '../components/TravelLineSearch.astro';
import Layout from '../layouts/Layout.astro';

const seaBenefits = [
  {
    title: 'Первая береговая линия',
    text: 'Если вам нужен отель в Джубге у моря, важнее всего реальное расстояние до пляжа. У нас это около 50 метров и примерно 1 минута пешком.',
  },
  {
    title: 'Подходит для коротких и длинных заездов',
    text: 'Гостевой дом удобен и для отпуска, и для нескольких ночей: море рядом, инфраструктура под рукой, а заселение проходит без лишней суеты.',
  },
  {
    title: 'Номера у моря без посредников',
    text: 'Официальный сайт помогает быстро перейти к бронированию, правилам проживания и прямому контакту с гостевым домом «Дельфин».',
  },
];
---

<Layout
  seoProfileId="otel_u_morya"
  canonicalPath="/otel-dzhubga-u-morya"
  schemaPageName="Отель в Джубге у моря"
  breadcrumbs={[
    { name: 'Главная', path: '/' },
    { name: 'Отель в Джубге у моря', path: '/otel-dzhubga-u-morya' },
  ]}
>
  <Header />
  <main id="main-content" class="bg-slate-50">
    <section class="pt-32 pb-12">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="mb-8">
          <TravelLineSearch />
        </div>

        <div class="bg-white rounded-3xl shadow-lg p-8 md:p-12">
          <h1 class="text-3xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
            Отель в Джубге у моря: гостевой дом «Дельфин» на первой линии
          </h1>
          <p class="text-lg text-slate-700 leading-relaxed mb-4">
            Когда нужен отель в Джубге у моря, ключевое преимущество «Дельфина» — реальная близость к пляжу.
            До берега всего 50 метров, поэтому отдых у моря начинается сразу после выхода с территории гостевого дома.
          </p>
          <p class="text-lg text-slate-700 leading-relaxed mb-8">
            Номера разных категорий, семейный формат проживания, парковка, Wi-Fi и прямое бронирование на официальном
            сайте делают этот вариант удобным для летнего отпуска, поездки с детьми и короткого курортного заезда.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="#"
              data-tl-booking-open="true"
              class="inline-flex items-center justify-center min-h-11 px-6 py-3 rounded-xl bg-accent-500 hover:bg-accent-600 text-white font-semibold transition-colors"
            >
              Забронировать номер
            </a>
            <a
              href="/#features"
              class="inline-flex items-center justify-center min-h-11 px-6 py-3 rounded-xl bg-primary-600 hover:bg-primary-700 text-white font-semibold transition-colors"
            >
              Изучить преимущества
            </a>
          </div>
        </div>
      </div>
    </section>

    <section class="pb-12">
      <div class="container mx-auto max-w-6xl px-4">
        <div class="grid gap-6 md:grid-cols-3">
          {seaBenefits.map((item) => (
            <div class="rounded-3xl bg-white p-6 shadow-lg">
              <h2 class="text-2xl font-bold text-slate-900">{item.title}</h2>
              <p class="mt-3 text-slate-600">{item.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="pb-20">
      <div class="container mx-auto max-w-5xl px-4">
        <div class="rounded-3xl bg-slate-900 p-8 text-white shadow-lg md:p-12">
          <h2 class="text-3xl font-bold">Кому подойдёт размещение у моря в Джубге</h2>
          <p class="mt-5 text-lg leading-relaxed text-slate-300">
            Эта страница создана для гостей, которые ищут отель в Джубге у моря и хотят жить рядом с пляжем, а не
            тратить время на дорогу. «Дельфин» удобно подходит семьям, парам и тем, кто ценит первую линию, тишину во дворе
            и быстрый доступ к набережной, кафе и магазинам.
          </p>
          <p class="mt-4 text-lg leading-relaxed text-slate-300">
            Если вам важно сочетание моря, удобных номеров и прямого контакта с объектом размещения, переходите на
            официальный сайт гостевого дома, выбирайте категорию номера и бронируйте проживание без посредников.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
