---
import Features from '../components/Features.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import CookieConsent from '../components/react/CookieConsent';
import FAQ from '../components/react/FAQ.jsx';
import FloatingBar from '../components/react/FloatingBar.jsx';
import Gallery from '../components/react/Gallery.jsx';
import Reviews from '../components/react/Reviews.jsx';
import RoomsList from '../components/react/RoomsList.jsx';
import { FAQ_DATA } from '../data/faq.js';
import Layout from '../layouts/Layout.astro';

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_DATA.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<Layout
  seoProfileId="home_hotel_cluster"
  canonicalPath="/"
  schemaPageName="Главная"
  breadcrumbs={[{ name: 'Главная', path: '/' }]}
  extraJsonLd={[faqJsonLd]}
>
  <Header />
  <main id="main-content">
    <Hero />
    <RoomsList client:load />
    <Features />
    <Reviews client:load />
    <Gallery client:load />
    <FAQ client:load />
  </main>
  <Footer />
  <FloatingBar client:load />
  <CookieConsent client:load />
</Layout>
