---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout
  seoProfileId="gostinicy_dzhubga"
  canonicalPath="/gostinicy-dzhubga"
  schemaPageName="Комфортный отдых в Джубге"
  breadcrumbs={[
    { name: 'Главная', path: '/' },
    { name: 'Комфортный отдых в Джубге', path: '/gostinicy-dzhubga' },
  ]}
>
  <Header />
  <main id="main-content" class="bg-slate-50">
    <section class="pt-32 pb-12">
      <div class="container mx-auto px-4 max-w-4xl">
        <div class="bg-white rounded-3xl shadow-lg p-8 md:p-12">
          <h1 class="text-3xl md:text-5xl font-bold text-slate-900 leading-tight mb-6">
            Комфортный формат отдыха в Джубге рядом с пляжем
          </h1>
          <p class="text-lg text-slate-700 leading-relaxed mb-4">
            Лаконичные интерьеры, спокойная атмосфера и продуманная территория позволяют проводить время без суеты,
            в нескольких минутах от моря.
          </p>
          <p class="text-lg text-slate-700 leading-relaxed mb-8">
            В пешей доступности находятся набережная, кафе и прогулочные зоны. Для гостей предусмотрена удобная
            парковка и оперативная обратная связь по всем вопросам.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href="/#booking-request"
              class="inline-flex items-center justify-center min-h-11 px-6 py-3 rounded-xl bg-accent-500 hover:bg-accent-600 text-white font-semibold transition-colors"
            >
              Отправить запрос
            </a>
            <a
              href="/#gallery"
              class="inline-flex items-center justify-center min-h-11 px-6 py-3 rounded-xl bg-primary-600 hover:bg-primary-700 text-white font-semibold transition-colors"
            >
              Посмотреть фотогалерею
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
