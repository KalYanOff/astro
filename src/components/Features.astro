---
const stats = [
  { value: '50 м', label: 'до моря' },
  { value: '30+', label: 'лет заботы о гостях' },
  { value: '4.9★', label: 'средняя оценка' },
  { value: '1000+', label: 'довольных семей' },
];

const features = [
  {
    icon: 'clock',
    title: 'На связи круглосуточно',
    description: 'Решаем Ваши вопросы в любое время, 24/7, чтобы ваш отдых оставался спокойным',
  },
  {
    icon: 'car',
    title: 'Бесплатная парковка',
    description: 'Закрытая охраняемая парковка прямо на территории без дополнительной оплаты - только у нас!',
  },
  {
    icon: 'baby',
    title: 'Детская площадка',
    description: 'Игровая зона с качелями и песочницей для семейного отдыха.',
  },
  {
    icon: 'home',
    title: 'Домашняя атмосфера',
    description: 'Тёплая обстановка и внимательное отношение к каждому гостю.',
  },
  {
    icon: 'location',
    title: 'Первая линия в Джубге',
    description: 'Море, пляж, набережная, кафе и магазины находятся в нескольких шагах от гостевого дома.',
  },
  {
    icon: 'fire',
    title: 'Зона барбекю',
    description: 'Для гостей оборудована мангальная зона и удобные места для вечернего отдыха на свежем воздухе.',
  },
  {
    icon: 'green',
    title: 'Зелёная территория',
    description: 'Много тени, зелени и тихих мест для спокойствия. У нас лучший приусадебный участок!',
  },
  {
    icon: 'wifi',
    title: 'Стабильный Wi-Fi',
    description: 'Надёжная связь для работы, общения и развлечений.',
  },
  {
    icon: 'price',
    title: 'Выгодные цены',
    description: 'Комфортный отдых у моря по разумной стоимости.',
  },
];
---

<section id="features" class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-100 text-amber-700 text-sm font-semibold mb-4">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
        </svg>
        Почему выбирают нас
      </div>
      <h2 class="text-4xl font-bold text-slate-900 mb-4">Мы знаем, что для Вас действительно важно</h2>
    </div>

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 mb-16">
      {stats.map((stat) => (
        <div class="text-center p-5 bg-white rounded-2xl shadow-lg border border-white-500 hover:bg-slate-50 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 animate-fade-in">
          <div class="font-display font-bold text-3xl sm:text-4xl text-primary-600 mb-1">{stat.value}</div>
          <div class="text-sm text-gray-600 font-medium">{stat.label}</div>
        </div>
      ))}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature, index) => (
        <div class="flex gap-4 p-6 rounded-xl hover:bg-slate-50 transition-all duration-300 hover:shadow-lg hover:-translate-y-1 animate-fade-in" style={`animation-delay: ${index * 100}ms`}>
          <div class="flex-shrink-0">
            <div class="w-14 h-14 rounded-full bg-white-100 flex items-center justify-center">
              {feature.icon === 'car' && (
                <img src="/img/icons/parking.png" alt="Парковка" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'baby' && (
                <img src="/img/icons/child.png" alt="Детская площадка" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'clock' && (
                <img src="/img/icons/open.png" alt="Круглосуточная связь" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'home' && (
                <img src="/img/icons/love.png" alt="Атмосфера уюта" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'location' && (
                <img src="/img/icons/location.png" alt="Расположение рядом с морем" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'wifi' && (
                <img src="/img/icons/wifi.png" alt="Wi-Fi" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'green' && (
                <img src="/img/icons/green.png" alt="Зелёная территория" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'price' && (
                <img src="/img/icons/price.png" alt="Доступная цена" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
              {feature.icon === 'fire' && (
                <img src="/img/icons/fire.png" alt="Зона барбекю" width="40" height="40" class="w-10 h-10 object-contain" loading="lazy" decoding="async" />
              )}
            </div>
          </div>
          <div>
            <h3 class="text-lg font-bold text-slate-900 mb-2">{feature.title}</h3>
            <p class="text-slate-600">{feature.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
