---
import { Baby, Car, Clock } from 'lucide-react';
import TravelLineSearch from './TravelLineSearch.astro';
---

<section
  id="hero"
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-28 pb-10 md:pt-36 md:pb-12"
>
  <picture class="absolute inset-0 z-0">
    <source srcset="/img/photo/beach/beach.avif" type="image/avif" />
    <source srcset="/img/photo/beach/beach.webp" type="image/webp" />
    <img
      src="/img/photo/beach/beach.webp"
      alt="Пляж Джубги рядом с гостевым пространством Дельфин"
      width="1920"
      height="1080"
      fetchpriority="high"
      decoding="async"
      class="w-full h-full object-cover"
    />
  </picture>

  <div class="absolute inset-0 bg-gradient-to-b from-slate-900/70 via-slate-900/50 to-slate-900/70 z-10"></div>

  <div class="relative z-20 container mx-auto px-4 text-center animate-fade-in w-full">
    <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl font-bold text-white mb-4 md:mb-6 drop-shadow-2xl leading-tight px-2">
      Дельфин, Джубга
      <br />
      <span class="text-accent-400 text-2xl sm:text-3xl md:text-4xl">
        Тёплый отдых в 50 метрах от моря, с атмосферой тишины и уюта
      </span>
    </h1>

    <div class="flex flex-wrap justify-center gap-2 md:gap-4 mb-4 md:mb-6">
      <div class="flex items-center gap-1.5 bg-white/90 backdrop-blur-sm rounded-full px-3 py-2 md:px-5 md:py-3 shadow-lg hover:scale-105 transition-transform">
        <Car class="w-4 h-4 md:w-5 md:h-5 text-primary-600 shrink-0" />
        <span class="text-xs md:text-sm font-medium text-slate-700 whitespace-nowrap">Бесплатная парковка</span>
      </div>
      <div class="flex items-center gap-1.5 bg-white/90 backdrop-blur-sm rounded-full px-3 py-2 md:px-5 md:py-3 shadow-lg hover:scale-105 transition-transform">
        <Clock class="w-4 h-4 md:w-5 md:h-5 text-primary-600 shrink-0" />
        <span class="text-xs md:text-sm font-medium text-slate-700 whitespace-nowrap">На связи 24/7</span>
      </div>
      <div class="flex items-center gap-1.5 bg-white/90 backdrop-blur-sm rounded-full px-3 py-2 md:px-5 md:py-3 shadow-lg hover:scale-105 transition-transform">
        <Baby class="w-4 h-4 md:w-5 md:h-5 text-primary-600 shrink-0" />
        <span class="text-xs md:text-sm font-medium text-slate-700 whitespace-nowrap">Детская площадка</span>
      </div>
    </div>

    <div class="flex justify-center mb-6 md:mb-8">
      <div class="inline-flex items-center gap-2 bg-white/95 backdrop-blur-sm rounded-full px-3 py-1.5 shadow-lg">
        <div class="flex">
          {[1, 2, 3, 4, 5].map(() => (
            <svg class="w-3.5 h-3.5 md:w-4 md:h-4 fill-yellow-400 text-yellow-400" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
            </svg>
          ))}
        </div>
        <span class="text-xs md:text-sm font-medium text-slate-700">4.9 на основе 250+ отзывов</span>
      </div>
    </div>

    <div class="flex flex-col items-center gap-5">
      <div class="w-full max-w-6xl">
        <TravelLineSearch />
      </div>

      <a
        href="#rooms"
        onclick="event.preventDefault(); document.querySelector('#rooms')?.scrollIntoView({ behavior: 'smooth', block: 'start' });"
        class="group flex flex-col items-center gap-1 text-white/70 hover:text-white transition-colors duration-200 cursor-pointer"
        aria-label="Смотреть варианты размещения"
      >
        <span class="text-sm font-medium tracking-wide">Смотреть варианты размещения</span>
        <svg
          class="w-6 h-6 animate-bounce-soft"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </a>
    </div>

  </div>
</section>
